def lognormal_params_from_mean_cv(mean, cv):
    sd = cv * mean
    sigma2 = np.log(1 + (sd**2 / mean**2))
    sigma = np.sqrt(sigma2)
    mu = np.log(mean) - 0.5 * sigma2
    return {
        "mean_service_days": mean,
        "cv": cv,
        "sd_service_days": sd,
        "meanlog": mu,
        "sdlog": sigma,
    }
                
